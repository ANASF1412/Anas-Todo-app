# TODO APP - MERN STACK ENVIRONMENT VARIABLES

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas Connection
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/todoapp?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/todoapp?retryWrites=true&w=majority

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (for future authentication)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Server URL
VITE_API_URL=http://localhost:5000

# ============================================
# DEPLOYMENT (Vercel, Heroku, etc.)
# ============================================

# When deploying, update these values:
# MONGO_URI=your_production_mongodb_uri
# FRONTEND_URL=your_production_frontend_url
# JWT_SECRET=your_production_jwt_secret
