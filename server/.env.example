# Backend Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection String
# Get your MongoDB Atlas URI from https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/todoapp?retryWrites=true&w=majority

# Frontend URL
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production_min_32_chars_12345
JWT_EXPIRE=7d

# Production Deployment
# NODE_ENV=production
# PORT=3000
# MONGO_URI=your_production_mongodb_uri
# FRONTEND_URL=your_production_frontend_url
# JWT_SECRET=your_production_jwt_secret_key
